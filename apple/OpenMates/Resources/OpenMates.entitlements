<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Passkey / WebAuthn + Handoff universal links — associates app with openmates.org -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>webcredentials:openmates.org</string>
		<string>webcredentials:dev.openmates.org</string>
		<string>applinks:openmates.org</string>
		<string>applinks:dev.openmates.org</string>
		<string>activitycontinuation:openmates.org</string>
		<string>activitycontinuation:dev.openmates.org</string>
	</array>

	<!-- Keychain sharing for E2EE master key storage -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)org.openmates.app</string>
	</array>

	<!-- iCloud Keychain sync for multi-device key access -->
	<key>com.apple.developer.icloud-container-identifiers</key>
	<array/>
	<key>com.apple.developer.icloud-services</key>
	<array>
		<string>CloudKit</string>
	</array>

	<!-- Credential provider for passkey autofill -->
	<key>com.apple.developer.authentication-services.autofill-credential-provider</key>
	<true/>

	<!-- App group for shared data between main app and extensions -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.org.openmates.app</string>
	</array>

	<!-- Push notifications (APNs) -->
	<key>aps-environment</key>
	<string>development</string>
</dict>
</plist>

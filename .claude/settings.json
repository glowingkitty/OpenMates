{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/.claude/hooks/skill-embed-registry-guard.sh"
          },
          {
            "type": "command",
            "command": "bash scripts/lint-design-tokens.sh"
          },
          {
            "type": "command",
            "command": "bash scripts/lint-swift-design-tokens.sh"
          }
        ]
      }
    ]
  }
}

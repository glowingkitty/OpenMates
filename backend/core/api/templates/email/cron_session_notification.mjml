<mjml>
  <mj-head>
    <mj-title>{{ t.email.cron_session_notification.title.text }}</mj-title>
    <mj-attributes>
      <mj-all font-family="Arial, Helvetica, sans-serif" font-size="16px" align="center" font-weight="bold" line-height="1.3" />
      {% if darkmode %}
      <mj-text color="#e6e6e6" />
      {% else %}
      <mj-text color="#000000" />
      {% endif %}
    </mj-attributes>
    <mj-include path="./components/email-styles.mjml" />
  </mj-head>
  <mj-body css-class="{% if darkmode %}dark-mode{% else %}light-mode{% endif %}">
    <mj-include path="./components/header.mjml" />

    <mj-wrapper css-class="content-box" padding="20px" padding-bottom="0">
      <mj-section>
        <mj-column>
          <mj-text font-size="26px" padding-bottom="20px">
            <mark>{{ t.email.cron_session_notification.header.text }}</mark>
          </mj-text>

          <!-- Status badge -->
          <mj-text font-size="18px" padding-bottom="20px">
            <span style="background-color: {{ status_color }}; color: #ffffff; padding: 4px 12px; border-radius: 4px; font-weight: bold;">
              {{ status | upper }}
            </span>
          </mj-text>

          <!-- Job type -->
          <mj-text font-size="16px" padding-bottom="15px">
            <strong>{{ t.email.cron_session_notification.job_type_label.text }}:</strong><br/>
            {{ job_display }}
          </mj-text>

          <!-- Session title -->
          <mj-text font-size="16px" padding-bottom="15px">
            <strong>{{ t.email.cron_session_notification.session_label.text }}:</strong><br/>
            {{ job_name }}
          </mj-text>

          {% if duration %}
          <mj-text font-size="16px" padding-bottom="15px">
            <strong>{{ t.email.cron_session_notification.duration_label.text }}:</strong><br/>
            {{ duration }}
          </mj-text>
          {% endif %}

          {% if exit_code is not none and exit_code != 0 %}
          <mj-text font-size="16px" padding-bottom="15px">
            <strong>{{ t.email.cron_session_notification.exit_code_label.text }}:</strong><br/>
            <span style="color: #F44336; font-weight: bold;">{{ exit_code }}</span>
          </mj-text>
          {% endif %}

          {% if session_id %}
          <mj-text font-size="16px" padding-bottom="15px">
            <strong>{{ t.email.cron_session_notification.session_id_label.text }}:</strong><br/>
            <code style="background-color: {% if darkmode %}#2d2d2d{% else %}#f5f5f5{% endif %}; padding: 2px 6px; border-radius: 3px; font-size: 14px;">{{ session_id }}</code>
          </mj-text>

          <mj-text font-size="13px" padding-bottom="15px" font-style="italic">
            {{ t.email.cron_session_notification.resume_hint.text }}:<br/>
            <code style="background-color: {% if darkmode %}#2d2d2d{% else %}#f5f5f5{% endif %}; padding: 2px 6px; border-radius: 3px; font-size: 12px;">claude -p "continue" --resume {{ session_id }}</code>
          </mj-text>
          {% endif %}

          {% if context_summary %}
          <mj-text font-size="16px" padding-bottom="15px">
            <strong>{{ t.email.cron_session_notification.summary_label.text }}:</strong><br/>
            <pre style="background-color: {% if darkmode %}#2d2d2d{% else %}#f5f5f5{% endif %}; padding: 10px; border-radius: 4px; font-size: 13px; white-space: pre-wrap; word-wrap: break-word; text-align: left;">{{ context_summary }}</pre>
          </mj-text>
          {% endif %}

          <mj-text font-size="14px" padding-bottom="30px" font-style="italic">
            {{ t.email.cron_session_notification.footer_note.text }}
          </mj-text>
        </mj-column>
      </mj-section>
    </mj-wrapper>

    <mj-include path="./components/footer.mjml" />
  </mj-body>
</mjml>

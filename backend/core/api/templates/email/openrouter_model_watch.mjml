<mjml>
  <mj-head>
    <mj-title>New OpenRouter Models</mj-title>
    <mj-attributes>
      <mj-all font-family="Arial, Helvetica, sans-serif" font-size="16px" line-height="1.3" />
      <mj-text color="#e6e6e6" />
    </mj-attributes>
  </mj-head>
  <mj-body background-color="#0f0f14">
    <mj-section background-color="#191923" border-radius="12px" padding="24px">
      <mj-column>
        <mj-text font-size="28px" font-weight="bold" align="center" padding-bottom="8px">
          New OpenRouter models available
        </mj-text>
        <mj-text font-size="14px" align="center" color="#aaaaaa" padding-bottom="20px">
          {{ model_count }} model(s), generated {{ generated_at }} UTC{% if not test_mode %}, lookback {{ lookback_minutes }} minutes{% endif %}
        </mj-text>
        <mj-text font-size="13px" color="#aaaaaa" padding-bottom="20px">
          Artifact: <code>{{ artifact_path }}</code>
        </mj-text>

        {% for model in models %}
        <mj-text font-size="18px" font-weight="bold" padding-top="18px" padding-bottom="6px">
          {{ model.name }}
        </mj-text>
        <mj-text font-size="13px" padding="4px 0">
          <strong>ID:</strong> <code>{{ model.id }}</code><br />
          <strong>Created:</strong> {{ model.created_at }}<br />
          <strong>Context:</strong> {{ model.context_length }} tokens<br />
          <strong>Max completion:</strong> {{ model.max_completion_tokens }} tokens<br />
          <strong>Modalities:</strong> {{ model.input_modalities | join(', ') }} -&gt; {{ model.output_modalities | join(', ') }}<br />
          <strong>Pricing:</strong> prompt {{ model.prompt_price }}, completion {{ model.completion_price }}<br />
          <strong>Cache:</strong> read {{ model.cache_read_price }}, write {{ model.cache_write_price }}<br />
          <strong>Supported params:</strong> {{ model.supported_parameters }}<br />
          <strong>Details:</strong> <a href="{{ model.details_url }}">{{ model.details_url }}</a>
        </mj-text>
        <mj-text font-size="13px" color="#bbbbbb" padding="4px 0 12px 0">
          {{ model.description }}
        </mj-text>
        {% endfor %}
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>

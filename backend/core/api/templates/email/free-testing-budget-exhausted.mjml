<mjml>
  <mj-head>
    <mj-title>Free testing credits budget exhausted</mj-title>
    <mj-attributes>
      <mj-all font-family="Arial, Helvetica, sans-serif" font-size="16px" align="center" font-weight="bold" line-height="1.3" />
      {% if darkmode %}
      <mj-text color="#e6e6e6" />
      {% else %}
      <mj-text color="#000000" />
      {% endif %}
    </mj-attributes>
    <mj-include path="./components/email-styles.mjml" />
  </mj-head>
  <mj-body css-class="{% if darkmode %}dark-mode{% else %}light-mode{% endif %}">
    <mj-include path="./components/header.mjml" />

    <mj-wrapper css-class="content-box" padding="20px" padding-bottom="0">
      <mj-section>
        <mj-column>
          <mj-text font-size="30px">
            <mark>Free testing credits budget exhausted</mark>
          </mj-text>
          <mj-text font-size="18px" padding-bottom="20px">
            The Free testing credits promotion no longer has enough remaining budget for another per-user grant.
          </mj-text>
          <mj-text font-size="16px" padding-bottom="8px">
            Total budget: <strong>{{ total_budget_credits }}</strong> credits
          </mj-text>
          <mj-text font-size="16px" padding-bottom="8px">
            Used budget: <strong>{{ used_budget_credits }}</strong> credits
          </mj-text>
          <mj-text font-size="16px" padding-bottom="8px">
            Remaining budget: <strong>{{ remaining_budget_credits }}</strong> credits
          </mj-text>
          <mj-text font-size="16px" padding-bottom="24px">
            Per-user grant: <strong>{{ per_user_grant_credits }}</strong> credits
          </mj-text>
          <mj-text font-size="16px" padding-bottom="20px">
            Increase the budget or disable the promotion in Server settings if signup should stop advertising free testing credits.
          </mj-text>
        </mj-column>
      </mj-section>
    </mj-wrapper>

    <mj-include path="./components/footer.mjml" />
  </mj-body>
</mjml>

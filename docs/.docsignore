# Documentation Ignore File
# 
# This file defines which folders and files should be excluded
# from the documentation processing system (process-docs.js).
#
# Format: One pattern per line
# Supports glob patterns and directory names

# Exclude image/asset directories (they're assets, not documentation)
images/
assets/
figma-newchat/

# Exclude developer contribution docs (guides, standards — not user-facing)
contributing/

# Exclude any temporary or draft files
*.draft.md
*.temp.md
*_temp.md
*_draft.md

# Exclude any files with TODO in the name
*todo*.md
*TODO*.md

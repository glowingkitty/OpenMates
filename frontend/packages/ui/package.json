{
  "name": "@repo/ui",
  "version": "0.0.0",
  "type": "module",
  "module": "index.ts",
  "main": "index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "svelte": "./index.ts"
    },
    "./demo_chats": {
      "types": "./src/demo_chats/index.ts",
      "svelte": "./src/demo_chats/index.ts",
      "default": "./src/demo_chats/index.ts"
    },
    "./src/demo_chats/resolveI18nServer": {
      "types": "./src/demo_chats/resolveI18nServer.ts",
      "default": "./src/demo_chats/resolveI18nServer.ts"
    },
    "./legal": {
      "types": "./src/legal/index.ts",
      "svelte": "./src/legal/index.ts",
      "default": "./src/legal/index.ts"
    },
    "./components/*": "./src/components/*",
    "./components/settings/elements": {
      "types": "./src/components/settings/elements/index.ts",
      "svelte": "./src/components/settings/elements/index.ts",
      "default": "./src/components/settings/elements/index.ts"
    },
    "./src/styles/*": "./src/styles/*",
    "./config/api": {
      "types": "./src/config/api.ts",
      "default": "./src/config/api.ts"
    },
    "./services/clientLogForwarder": {
      "types": "./src/services/clientLogForwarder.ts",
      "default": "./src/services/clientLogForwarder.ts"
    },
    "./services/shortUrlEncryption": {
      "types": "./src/services/shortUrlEncryption.ts",
      "default": "./src/services/shortUrlEncryption.ts"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "generate-apps-metadata": "node scripts/generate-apps-metadata.js",
    "generate-embed-registry": "node scripts/generate-embed-registry.js",
    "generate-models-metadata": "node scripts/generate-models-metadata.js",
    "generate-providers-metadata": "node scripts/generate-providers-metadata.js",
    "generate-icon-urls": "node scripts/generate-icon-urls.js",
    "generate-privacy-promises": "node scripts/generate-privacy-promises.js",
    "build:tokens": "node scripts/build-tokens.js",
    "build:translations": "node scripts/build-translations.js",
    "validate:locales": "node scripts/validate-locales.js",
    "validate:icon-refs": "node scripts/validate-icon-refs.js",
    "update:translations": "node scripts/update-yaml-files.js",
    "prepare": "npm run build:tokens && npm run build:translations && npm run validate:locales && npm run generate-apps-metadata && npm run generate-embed-registry && npm run generate-models-metadata && npm run generate-providers-metadata && npm run generate-icon-urls && npm run generate-privacy-promises && npm run validate:icon-refs",
    "prebuild": "npm run build:translations && npm run validate:locales && npm run generate-apps-metadata && npm run generate-embed-registry && npm run generate-models-metadata && npm run generate-providers-metadata && npm run generate-icon-urls && npm run generate-privacy-promises && npm run validate:icon-refs",
    "build": "npm run build:translations && npm run validate:locales && npm run generate-apps-metadata && npm run generate-embed-registry && npm run generate-models-metadata && npm run generate-providers-metadata && npm run generate-icon-urls && npm run generate-privacy-promises && npm run validate:icon-refs"
  },
  "dependencies": {
    "@fontsource-variable/lexend-deca": "^5.2.9",
    "@lucide/svelte": "^0.545.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-zone": "^2.6.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/instrumentation": "^0.214.0",
    "@opentelemetry/instrumentation-fetch": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-trace-web": "^2.6.1",
    "@polar-sh/checkout": "^0.2.0",

    "@stripe/stripe-js": "^7.9.0",
    "@sveltejs/adapter-auto": "^6.1.0",
    "@sveltejs/kit": "^2.57.1",
    "@tiptap/core": "^3.4.3",
    "@tiptap/extension-highlight": "^3.4.3",
    "@tiptap/extension-link": "^3.4.3",
    "@tiptap/extension-mathematics": "^3.4.3",
    "@tiptap/extension-placeholder": "^3.4.3",
    "@tiptap/extension-strike": "^3.4.3",
    "@tiptap/extension-table": "^3.4.3",
    "@tiptap/extension-table-cell": "^3.4.3",
    "@tiptap/extension-table-header": "^3.4.3",
    "@tiptap/extension-table-row": "^3.4.3",
    "@tiptap/extension-underline": "^3.4.3",
    "@tiptap/pm": "^3.4.3",
    "@tiptap/starter-kit": "^3.4.3",
    "@toon-format/toon": "^1.1.0",
    "@types/leaflet": "^1.9.20",
    "@types/lodash-es": "^4.17.12",
    "@types/pica": "^9.0.5",
    "@types/uuid": "^10.0.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.0",
    "function-plot": "1.25.3",
    "highlight.js": "^11.11.1",
    "highlightjs-svelte": "^1.0.6",
    "html-docx-js-typescript": "0.1.5",
    "jspdf": "4.2.1",
    "jszip": "^3.10.1",
    "katex": "^0.16.22",
    "leaflet": "^1.9.4",
    "lodash-es": "^4.17.23",
    "lowlight": "^3.3.0",
    "markdown-it": "^14.1.1",
    "pica": "^9.0.1",
    "prosemirror-state": "^1.4.3",
    "prosemirror-view": "^1.41.0",
    "qrcode-svg": "^1.1.0",
    "svelte-i18n": "^4.0.1",
    "tweetnacl": "^1.0.3",
    "uuid": "^13.0.0",
    "vite": "^7.3.2",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tsconfig/svelte": "^5.0.5",
    "@types/leaflet": "^1.9.8",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.35.0",
    "jsdom": "^25.0.1",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.3",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}

{
	"installCommand": "cd ../.. && pnpm install --no-frozen-lockfile",
	"rewrites": [
		{
			"source": "/dev/:path*",
			"destination": "/"
		},
		{
			"source": "/((?!_app|static|docs|status|announcements|tips|favicon\\.ico|robots\\.txt|sitemap\\.xml|\\.well-known/apple-app-site-association).*)",
			"destination": "/"
		}
	],
	"headers": [
		{
			"source": "/.well-known/apple-app-site-association",
			"headers": [
				{
					"key": "Content-Type",
					"value": "application/json"
				},
				{
					"key": "Cache-Control",
					"value": "public, max-age=3600"
				}
			]
		},
		{
			"source": "/",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "no-cache, no-store, must-revalidate"
				}
			]
		},
		{
			"source": "/(.*).html",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "no-cache, no-store, must-revalidate"
				}
			]
		},
		{
			"source": "/_app/version.json",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "no-cache, no-store, must-revalidate"
				}
			]
		},
		{
			"source": "/_app/immutable/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		}
	]
}
